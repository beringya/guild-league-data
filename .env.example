APP_NAME=逆水寒帮会联赛数据分析平台
APP_VERSION=1.0.0
DATABASE_URL=sqlite:////app/data/app.db
DATA_DIR=/app/data
BACKUP_DIR=/app/backups
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false
CORS_ORIGINS=
ADMIN_USERNAME=admin
APP_PORT=18080
COMPOSE_PROJECT_NAME=nsh-guild-analytics
APP_DATA_DIR=./data
APP_BACKUP_DIR=./backups

# Optional PostgreSQL mode, used with docker-compose.postgres.yml
POSTGRES_USER=nsh_guild
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=nsh_guild_analytics
APP_POSTGRES_DIR=./postgres
