APP_NAME=逆水寒帮会联赛数据分析平台
APP_VERSION=1.0.0
GIN_MODE=release
APP_PORT=18080
PUBLIC_URL=http://localhost:18080
COMPOSE_PROJECT_NAME=nsh-guild-analytics
TZ=Asia/Shanghai

POSTGRES_USER=nsh_guild
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=nsh_guild_analytics
DATABASE_DSN=postgres://nsh_guild:replace-with-a-long-random-password@postgres:5432/nsh_guild_analytics?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL=8h
COOKIE_SECURE=false
CSRF_HEADER=X-CSRF-Token
LOGIN_FAILURE_LIMIT=5
IMPORT_PREVIEW_TTL=30m

UPLOAD_DIR=/app/data/uploads
BACKUP_DIR=/app/backups
STATIC_DIR=/app/public
