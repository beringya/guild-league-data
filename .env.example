APP_NAME=逆水寒帮会联赛数据分析平台
APP_VERSION=1.0.0
GIN_MODE=release
APP_PORT=18080
PUBLIC_URL=http://localhost:18080
COMPOSE_PROJECT_NAME=nsh-guild-analytics
DEPLOY_DIR_HOST=/opt/nsh-guild-analytics
APP_IMAGE=ghcr.io/beringya/guild-league-data:1.0.0
APP_IMAGE_REPOSITORY=ghcr.io/beringya/guild-league-data
TZ=Asia/Shanghai

UPDATE_GITHUB_REPO=beringya/guild-league-data
UPDATE_CHECK_URL=
UPDATE_DOWNLOAD_URL=
UPDATE_INSTALL_COMMAND=cd /opt/nsh-guild-analytics && docker compose pull app && docker compose up -d --no-build app
UPDATE_APPLY_ENABLED=true
UPDATE_APPLY_COMMAND=/app/bin/update-image.sh
UPDATE_CHANNEL=stable
UPDATE_CHECK_TIMEOUT=3s

POSTGRES_USER=nsh_guild
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=nsh_guild_analytics
DATABASE_DSN=postgres://nsh_guild:replace-with-a-long-random-password@postgres:5432/nsh_guild_analytics?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL=8h
COOKIE_SECURE=false
CSRF_HEADER=X-CSRF-Token
LOGIN_FAILURE_LIMIT=5
IMPORT_PREVIEW_TTL=30m

UPLOAD_DIR=/app/data/uploads
BACKUP_DIR=/app/backups
STATIC_DIR=/app/public
