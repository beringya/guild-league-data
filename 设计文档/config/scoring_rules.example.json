{
  "version": "v1.5-final",
  "status": "all_requirements_confirmed",
  "normalization": {
    "method": "career_metric_range_linear",
    "formula_higher": "clamp((value-min)/(max-min),0,1)*100",
    "formula_lower": "clamp((max-value)/(max-min),0,1)*100",
    "score_range": [
      0,
      100
    ],
    "range_suggestion": {
      "first_import_pool": "same_battle_same_career_both_guilds",
      "large_sample_method": "p05_p95",
      "large_sample_min_n": 20,
      "small_sample_method": "min_max_with_margin",
      "small_sample_margin_ratio": 0.1,
      "very_small_sample_warning_below_n": 3,
      "non_negative_floor": 0,
      "requires_admin_confirmation": true,
      "published_ranges_are_frozen": true,
      "new_imports_do_not_auto_update_published_ranges": true,
      "changes_create_new_version": true,
      "historical_reanalysis_is_explicit": true
    },
    "comparison_percentile_pool": "same_battle_same_career_both_guilds"
  },
  "derived_metrics": {
    "head_ratio": "kda_ratio",
    "kda_formula": "(kills + assists) / max(deaths, 1)",
    "participation_rate_formula": "(kills + assists) / guild_total_kills",
    "player_damage_share_formula": "player_damage / guild_total_player_damage",
    "building_damage_share_formula": "building_damage / guild_total_building_damage",
    "player_damage_conversion_rate": "normalized player_damage score under career range / 100",
    "building_damage_conversion_rate": "normalized building_damage score under career range / 100",
    "kda_zero_deaths_behavior": "use_denominator_1_and_show_no_death_badge"
  },
  "six_dimension_schema": {
    "required_enabled_slots": 6,
    "allowed_metrics": [
      "kills",
      "assists",
      "player_damage",
      "building_damage",
      "healing",
      "damage_taken",
      "qingdeng",
      "revive",
      "control",
      "kda_ratio",
      "participation_rate"
    ],
    "ranking_weight_sum_for_active_profile": 1.0,
    "zero_weight_slots_are_analysis_only": true
  },
