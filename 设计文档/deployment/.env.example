# 基础
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
TZ=Asia/Shanghai
DATA_DIR=/app/data
DATABASE_URL=sqlite:////app/data/app.db
BACKUP_DIR=/app/backups

# 首次部署管理员：用户名固定为 admin，初始密码由程序随机生成并只在首次日志中显示一次。
ADMIN_USERNAME=admin
ADMIN_FORCE_PASSWORD_CHANGE=true

# 安全：部署前生成随机长字符串
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_HOURS=8
COOKIE_SECURE=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# 业务默认值
DEFAULT_HOME_GUILD=
COMPARISON_THRESHOLD_PERCENT=5
AUTO_BACKUP=true
BACKUP_RETENTION_DAYS=14
